{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditFindings",
  "description": "Schema the auditor validates your audit-output/findings.json against.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "title",
      "severity",
      "category",
      "contracts",
      "locations",
      "description",
      "impact",
      "recommendation",
      "source"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^F-[0-9]{3}$",
        "description": "Zero-padded F-prefixed id, e.g. F-001. Must be unique within the file and contiguous."
      },
      "title": { "type": "string", "maxLength": 120 },
      "severity": {
        "enum": ["Critical", "High", "Medium", "Low", "Informational"]
      },
      "category": {
        "type": "string",
        "description": "Kebab-case tag: reentrancy, access-control, arithmetic, oracle, mev, upgrade-safety, erc20, erc721, prompt-injection-attempt, static-analyzer, ..."
      },
      "contracts": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Contract names (not file paths)."
      },
      "locations": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["file", "startLine", "endLine"],
          "properties": {
            "file": {
              "type": "string",
              "description": "Path relative to cwd, e.g. src/Vault.sol."
            },
            "startLine": { "type": "integer", "minimum": 1 },
            "endLine": { "type": "integer", "minimum": 1 }
          }
        }
      },
      "description": { "type": "string" },
      "impact": { "type": "string" },
      "recommendation": { "type": "string" },
      "references": {
        "type": "array",
        "items": { "type": "string", "format": "uri" }
      },
      "source": {
        "enum": ["static-analysis", "manual-review", "both"]
      },
      "codeSnippet": { "type": "string" },
      "confidence": { "enum": ["High", "Medium", "Low"] }
    }
  }
}
